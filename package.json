{
  "name": "fridge-manager",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @fridge-manager/web dev",
    "dev:mobile": "pnpm --filter @fridge-manager/mobile start",
    "build:web": "pnpm --filter @fridge-manager/web build",
    "build:shared": "pnpm --filter @fridge-manager/shared build",
    "test": "pnpm -r test",
    "test:shared": "pnpm --filter @fridge-manager/shared test",
    "test:watch": "pnpm --filter @fridge-manager/shared test:watch",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "uuid": ">=14.0.0"
    }
  }
}
